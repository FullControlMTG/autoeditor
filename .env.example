# === Asset Paths ===
# All paths can be absolute or relative to the working directory.

INTRO_PATH=/path/to/assets/intro.mp4 (*nix) OR "C:/Path/To/Assets/intro.mp4" (DOS) (Can use full or relative paths, see input/output)
OUTRO_PATH=/path/to/assets/outro.mp4
TRANSITION_PATH=/path/to/assets/transition.mp4

# Midroll ad clips inserted after the deck tech (ad 1) and ~halfway through games (ad 2).
# Set the corresponding _ENABLED flag to false to skip an ad without removing its path.
MIDROLL_AD_PATH_1=assets/midroll_1.mp4
MIDROLL_AD_PATH_2=assets/midroll_2.mp4
MIDROLL_AD_1_ENABLED=true
MIDROLL_AD_2_ENABLED=true

# === Folders ===
# Root folder containing project subfolders (used in batch mode)
PROJECT_FOLDER_PATH="./input"

# Folder where rendered output files are written
OUTPUT_FOLDER="./output"

# === Batch Mode ===
# If true, process all project subfolders when running the `batch` command
PROCESS_MULTI=true

# === Output Settings ===
# Resolution of the final output video
TARGET_RESOLUTION=1920x1080

# Frames per second for the final output video
TARGET_FPS=60

# Crossfade duration (seconds) between content clips inside a group.
# Set to 0 for hard cuts everywhere (except where transition clips are used).
FADE_DURATION=0.3

# Fade-in and fade-out duration (seconds) applied to the very start/end of
# the final output video.
OUTPUT_FADE_DURATION=0.5

# === GPU Acceleration ===
# Video encoder to use for all encode passes.
# libx264   — CPU (default, always available)
# h264_nvenc — NVIDIA GPU (requires CUDA drivers)
# h264_amf   — AMD GPU
# h264_qsv   — Intel Quick Sync
VIDEO_ENCODER=libx264
